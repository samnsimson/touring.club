# Local development template (NODE_ENV=development). Copy to `.env` and fill in real values —
# `.env` is gitignored. Env files are loaded in this cascade (highest priority first), and a
# variable already present in the real process environment (shell/container/CI) always wins
# over every file below: .env.<NODE_ENV>.local -> .env.local -> .env.<NODE_ENV> -> .env
# See .env.staging.example / .env.production.example for those environments.

# Host port for the touring-club Postgres container (container always listens on 5432 internally).
# Use 5433 when another Postgres instance already occupies 5432 on your machine.
POSTGRES_PORT=5433

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/touring_club
BETTER_AUTH_SECRET=local-dev-better-auth-secret-32chars
AUTH_APP_URL=http://localhost:3000
EMAIL_PROVIDER=console
EMAIL_FROM=Touring Club <noreply@touring.club>

# AWS S3 (object storage) — leave ACCESS_KEY_ID/SECRET_ACCESS_KEY unset to use the default AWS credential chain.
# Set AWS_S3_ENDPOINT for S3-compatible providers (e.g. Cloudflare R2) or local dev (e.g. LocalStack/MinIO).
AWS_REGION=us-east-1
AWS_S3_BUCKET=touring-club-media
# AWS_S3_ENDPOINT=
# AWS_S3_PUBLIC_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
