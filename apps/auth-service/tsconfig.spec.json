{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./out-tsc/jest",
        "types": ["jest", "node"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": ["jest.config.ts", "jest.config.cts", "specs/**/*.test.ts", "specs/**/*.spec.ts", "specs/**/*.d.ts"],
    "references": [
        {
            "path": "./tsconfig.app.json"
        }
    ]
}
