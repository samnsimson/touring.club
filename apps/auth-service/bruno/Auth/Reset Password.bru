meta {
  name: Reset Password
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/auth/reset-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "{{resetToken}}",
    "newPassword": "{{password}}"
  }
}

docs {
  Reset the password using the token from the reset email.
}
