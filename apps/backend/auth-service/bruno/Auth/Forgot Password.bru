meta {
  name: Forgot Password
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/auth/forgot-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{email}}"
  }
}

docs {
  Request a password reset email. Always returns success to prevent email enumeration.
}
