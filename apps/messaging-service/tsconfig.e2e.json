{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./out-tsc/e2e",
        "types": ["jest", "node"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "composite": false,
        "declaration": false,
        "declarationMap": false,
        "emitDeclarationOnly": false,
        "noEmit": true
    },
    "include": ["__tests__/e2e/**/*.ts"],
    "references": [
        { "path": "./tsconfig.app.json" },
        { "path": "../../library/config/tsconfig.lib.json" },
        { "path": "../../library/core/tsconfig.lib.json" },
        { "path": "../../library/auth/tsconfig.lib.json" },
        { "path": "../../library/database/tsconfig.lib.json" },
        { "path": "../../library/testing/tsconfig.lib.json" },
        { "path": "../../library/utils/tsconfig.lib.json" }
    ]
}
