{
    "name": "messaging-service",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/messaging-service/src",
    "projectType": "application",
    "tags": ["messaging-service"],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "webpack-cli build",
                "env": {
                    "NODE_ENV": "production"
                },
                "cwd": "apps/messaging-service"
            },
            "configurations": {
                "development": {
                    "env": {
                        "NODE_ENV": "development"
                    }
                }
            }
        },
        "prune-lockfile": {
            "dependsOn": ["build"],
            "cache": true,
            "executor": "@nx/js:prune-lockfile",
            "outputs": ["{workspaceRoot}/apps/messaging-service/dist/package.json", "{workspaceRoot}/apps/messaging-service/dist/bun.lock"],
            "options": {
                "buildTarget": "build"
            }
        },
        "copy-workspace-modules": {
            "dependsOn": ["build"],
            "cache": true,
            "outputs": ["{workspaceRoot}/apps/messaging-service/dist/workspace_modules"],
            "executor": "@nx/js:copy-workspace-modules",
            "options": {
                "buildTarget": "build"
            }
        },
        "prune": {
            "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
            "executor": "nx:noop"
        },
        "serve": {
            "continuous": true,
            "executor": "@nx/js:node",
            "defaultConfiguration": "development",
            "dependsOn": [
                {
                    "target": "build",
                    "params": "forward"
                }
            ],
            "options": {
                "buildTarget": "messaging-service:build",
                "runBuildTargetDependencies": false
            },
            "configurations": {
                "development": {
                    "buildTarget": "messaging-service:build:development"
                },
                "production": {
                    "buildTarget": "messaging-service:build:production"
                }
            }
        },
        "e2e": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "apps/messaging-service/jest.e2e.config.cts",
                "passWithNoTests": false
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "apps/messaging-service/jest.config.cts",
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "coverage": true,
                    "coverageReporters": ["text", "html"]
                }
            }
        }
    }
}
