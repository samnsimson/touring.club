meta {
  name: Send Message
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/conversations/{{conversationId}}/messages
  body: json
  auth: bearer
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "body": "See you at the trailhead!"
  }
}

docs {
  Send a text message in a conversation.
}
