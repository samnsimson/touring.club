{
    "name": "web",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/frontend/web",
    "projectType": "application",
    "tags": ["web", "scope:frontend"],
    "// targets": "to see all targets run: nx show project web --web",
    "targets": {
        "build": {
            "command": "next build --webpack",
            "options": {
                "cwd": "apps/frontend/web"
            }
        },
        "dev": {
            "command": "next dev --webpack",
            "options": {
                "cwd": "apps/frontend/web"
            }
        },
        "start": {
            "command": "next start",
            "options": {
                "cwd": "apps/frontend/web"
            }
        }
    }
}
