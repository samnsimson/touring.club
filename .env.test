# Committed on purpose (unlike every other real .env* file — see .gitignore) — CI and local
# unit test runs need DATABASE_URL/BETTER_AUTH_SECRET to satisfy EnvSchema validation at module
# load time, even though these unit tests never open a real DB connection or call Better Auth.
# Values here are dummy placeholders only — never put a real secret in this file.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/touring_club_test
BETTER_AUTH_SECRET=test-only-secret-not-for-real-use-min-32-chars
