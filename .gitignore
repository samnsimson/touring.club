# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
.tmp
out-tsc

# generated OpenAPI specs
apps/backend/*/openapi

# dependencies
node_modules

# env files — real values (local dev secrets, per-env overrides) never get committed;
# only *.example templates should be tracked
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.test
!.env.example
!.env.*.example

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.nx/migrate-runs
.claude/worktrees
.claude/settings.local.json

test-output

.nx/polygraph

# Next.js
.next
out
