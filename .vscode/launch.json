{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug @touring.club/gateway-service with Nx",
            "runtimeExecutable": "bun",
            "runtimeArgs": ["nx", "serve", "@touring.club/gateway-service"],
            "env": {
                "NODE_OPTIONS": "--inspect=9229"
            },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"],
            "sourceMaps": true,
            "outFiles": ["${workspaceFolder}/apps/gateway-service/dist/**/*.(m|c|)js", "!**/node_modules/**"]
        },
        {
            "type": "node",
