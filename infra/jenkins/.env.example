# Copy to infra/jenkins/.env and adjust for your environment.
JENKINS_ADMIN_PASSWORD=admin
JENKINS_URL=http://localhost:8080/

# Git remote used by the seeded multibranch pipeline.
# Required for automatic job creation on Jenkins startup.
GIT_REPOSITORY_URL=https://github.com/your-org/touring.club.git

# CI secrets injected into Jenkins credentials (optional overrides).
# BETTER_AUTH_SECRET=replace-with-at-least-32-characters-secret
# JENKINS_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/touring_club
