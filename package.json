        "@nestjs/testing": "^11.0.0",
        "@next/eslint-plugin-next": "^16.1.6",
        "@nx/docker": "23.0.0",
        "@nx/esbuild": "23.0.0",
        "@nx/eslint": "23.0.0",
        "@nx/eslint-plugin": "23.0.0",
        "@nx/jest": "23.0.0",
        "@nx/js": "23.0.0",
        "@nx/nest": "23.0.0",
        "@nx/next": "23.0.0",
        "@nx/node": "23.0.0",
        "@nx/react": "23.0.0",
        "@nx/web": "23.0.0",
        "@nx/webpack": "23.0.0",
