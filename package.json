{
    "name": "@touring.club/source",
    "version": "0.0.0",
    "license": "MIT",
    "scripts": {
        "format": "prettier --write \"**/*.{js,ts,json}\"",
        "lint": "nx run-many --target=lint",
        "test": "nx run-many --target=test",
        "test:e2e": "nx run-many --target=e2e",
        "build": "nx run-many --target=build",
        "start:auth": "nx serve auth-service",
        "start:users": "nx serve users-service",
        "start:trips": "nx serve trips-service",
        "start": "nx run-many --target=serve",
        "auth:generate": "nx run auth:generate",
        "migration:run": "nx run database:migration:run",
        "migration:generate": "nx run database:migration:generate --name=Migration",
        "prepare": "husky"
    },
    "private": true,
    "dependencies": {
        "@hedystia/better-auth-typeorm": "^1.0.1",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/typeorm": "^11.0.2",
        "@thallesp/nestjs-better-auth": "^2.6.1",
        "axios": "^1.6.0",
        "better-auth": "^1.6.20",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cookie-parser": "^1.4.7",
        "express": "^5.2.1",
        "jose": "^6.2.3",
        "lodash": "^4.18.1",
        "pg": "^8.22.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "supertest": "^7.2.2",
        "typeorm": "^1.0.0",
        "typeorm-naming-strategy": "^2.0.19",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@better-auth/test-utils": "^1.6.20",
        "@eslint/js": "^9.8.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@nx/docker": "23.0.0",
        "@nx/esbuild": "23.0.0",
        "@nx/eslint": "23.0.0",
        "@nx/eslint-plugin": "23.0.0",
        "@nx/jest": "23.0.0",
        "@nx/js": "23.0.0",
        "@nx/nest": "23.0.0",
        "@nx/node": "23.0.0",
        "@nx/web": "23.0.0",
        "@nx/webpack": "23.0.0",
        "@nx/workspace": "23.0.0",
        "@swc/helpers": "~0.5.18",
        "@swc/jest": "~0.2.38",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/jest": "~30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^22.0.0",
        "better-sqlite3": "^12.11.1",
        "esbuild": "^0.27.0",
        "eslint": "^9.8.0",
        "eslint-config-prettier": "^10.0.0",
        "husky": "^9.1.7",
        "jest": "~30.3.0",
        "jest-environment-node": "~30.3.0",
        "jest-util": "~30.3.0",
        "jsonc-eslint-parser": "^2.1.0",
        "kysely": "^0.29.2",
        "lint-staged": "^17.0.8",
        "nx": "23.0.0",
        "prettier": "~3.6.2",
        "ts-jest": "^29.4.0",
        "ts-node": "10.9.1",
        "tslib": "^2.3.0",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.40.0",
        "vitest": "^4.1.9",
        "webpack": "^5.101.3",
        "webpack-cli": "^7.0.0",
        "webpack-dev-server": "^5.2.1"
    },
    "workspaces": [
        "apps/*",
        "library/*"
    ],
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml,css,scss,html}": [
            "prettier --write"
        ]
    },
    "patchedDependencies": {
        "@hedystia/better-auth-typeorm@1.0.1": "patches/@hedystia%2Fbetter-auth-typeorm@1.0.1.patch"
    }
}
