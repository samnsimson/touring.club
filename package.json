        "axios": "^1.6.0",
        "better-auth": "^1.6.20",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cookie-parser": "^1.4.7",
        "express": "^5.2.1",
        "jose": "^6.2.3",
        "lodash": "^4.18.1",
        "next": "~16.1.6",
        "pg": "^8.22.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "socket.io": "^4.8.1",
