{
    "name": "@touring.club/source",
    "version": "0.0.0",
    "license": "MIT",
    "scripts": {
        "format": "prettier --write \"**/*.{js,ts,json}\"",
        "lint": "nx run-many --target=lint",
        "test": "nx run-many --target=test",
        "build": "nx run-many --target=build",
        "start:auth": "nx serve auth-service",
        "start:users": "nx serve users-service",
        "start:trips": "nx serve trips-service",
        "start:messaging": "nx serve messaging-service",
        "start:notifications": "nx serve notifications-service",
        "start:web": "nx dev web",
        "start": "nx run-many --target=serve",
        "start:prod": "docker compose up -d postgres kong && nx run-many --target=serve --configuration=production",
        "auth:generate": "nx run auth:generate",
        "api:generate": "nx run-many --target=api:generate",
        "sdk:generate": "nx run-many --target=sdk:generate",
        "openapi:generate": "nx run-many --target=openapi:generate",
        "migration:run": "nx run database:migration:run",
        "migration:generate": "nx run database:migration:generate --name=Migration",
        "seed:trips": "nx run database:seed:trips",
        "openapi-ts": "openapi-ts",
        "prepare": "husky"
    },
    "private": true,
    "dependencies": {
        "@hedystia/better-auth-typeorm": "^1.0.1",
        "@nestjs/common": "^11.0.0",
