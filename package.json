        "@types/jest": "~30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^26.0.1",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "babel-jest": "~30.3.0",
        "better-sqlite3": "^12.11.1",
        "esbuild": "^0.27.0",
        "eslint": "^9.8.0",
        "eslint-config-next": "^16.1.6",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-import": "2.31.0",
        "eslint-plugin-jsx-a11y": "6.10.1",
