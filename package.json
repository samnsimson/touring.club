        "webpack": "^5.101.3",
        "webpack-cli": "^7.0.0",
        "webpack-dev-server": "^5.2.1"
    },
    "workspaces": [
        "apps/backend/*",
        "apps/frontend/*",
        "library/backend/*",
        "library/shared/*",
        "library/frontend/*"
    ],
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml,css,scss,html}": [
            "prettier --write"
        ]
    },
    "patchedDependencies": {
        "@hedystia/better-auth-typeorm@1.0.1": "patches/@hedystia%2Fbetter-auth-typeorm@1.0.1.patch"
    }
