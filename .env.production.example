# Production template (NODE_ENV=production). Documents which keys production needs — do not
# commit real values here or in a tracked `.env.production`. Real secrets belong in the deploy
# platform's secret store (CI secrets, cloud secret manager) and are injected as real process
# env vars, which always take precedence over any dotenv file (see .env.example for the cascade).

DATABASE_URL=postgresql://<user>:<password>@<production-db-host>:5432/touring_club
BETTER_AUTH_SECRET=<32+ char secret, unique per environment — never reuse the dev/staging value>
AUTH_APP_URL=https://touring.club

EMAIL_PROVIDER=resend
EMAIL_FROM=Touring Club <noreply@touring.club>
RESEND_API_KEY=<production Resend API key>

AWS_REGION=us-east-1
AWS_S3_BUCKET=touring-club-media
# AWS_S3_ENDPOINT=
# AWS_S3_PUBLIC_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
