# Staging template (NODE_ENV=staging). Documents which keys staging needs — do not commit real
# values here or in a tracked `.env.staging`. Real secrets belong in the deploy platform's
# secret store (CI secrets, cloud secret manager) and are injected as real process env vars,
# which always take precedence over any dotenv file (see .env.example for the full cascade).

DATABASE_URL=postgresql://<user>:<password>@<staging-db-host>:5432/touring_club
BETTER_AUTH_SECRET=<32+ char secret, unique per environment — never reuse the dev value>
AUTH_APP_URL=https://staging.touring.club

EMAIL_PROVIDER=resend
EMAIL_FROM=Touring Club <noreply@touring.club>
RESEND_API_KEY=<staging Resend API key>

AWS_REGION=us-east-1
AWS_S3_BUCKET=touring-club-media-staging
# AWS_S3_ENDPOINT=
# AWS_S3_PUBLIC_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
