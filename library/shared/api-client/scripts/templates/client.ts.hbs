{{#each services}}
import { Sdk as {{sdkImport}} } from './lib/{{service}}-client';
{{/each}}

{{#each services}}
import { createClient as {{createClientImport}} } from './lib/{{service}}-client/client';
{{/each}}

import { baseClientConfig } from './utils/client.utils';
import { ApiClientConfig } from './contract/client.contract';

export class ApiClient {
{{#each services}}
    public readonly {{field}}: {{sdkImport}};
{{/each}}

    constructor(config: ApiClientConfig = {}) {
{{#each services}}
        this.{{field}} = new {{sdkImport}}({ client: {{createClientImport}}(baseClientConfig(config)) });
{{/each}}
    }
}
