{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./out-tsc/jest",
        "jsx": "react-jsx",
        "types": ["jest", "node"]
    },
    "include": [
        "jest.config.ts",
        "jest.config.cts",
        "__tests__/unit/**/*.spec.ts",
        "__tests__/unit/**/*.test.ts",
        "__tests__/unit/**/*.spec.tsx",
        "__tests__/unit/**/*.test.tsx",
        "src/**/*.d.ts"
    ],
    "references": [
        {
            "path": "./tsconfig.lib.json"
        }
    ]
}
