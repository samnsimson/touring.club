{
    "name": "@tc/client-api",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "@touring.club/source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./types/*": {
            "@touring.club/source": "./src/types/*.ts",
            "types": "./dist/types/*.d.ts",
            "import": "./dist/types/*.js",
            "default": "./dist/types/*.js"
        }
    },
    "dependencies": {
        "@tc/api-sdk": "workspace:*"
    },
    "devDependencies": {
        "handlebars": "^4.7.9",
        "prettier": "~3.6.2"
    }
}
