{
    "name": "utils",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "library/utils/src",
    "projectType": "library",
    "tags": ["utils", "shared"],
    "targets": {
        "build": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "library/utils/dist",
                "main": "library/utils/src/index.ts",
                "tsConfig": "library/utils/tsconfig.lib.json",
                "declarationRootDir": "library/utils/src"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "cwd": "{workspaceRoot}",
            "options": {
                "jestConfig": "library/utils/jest.config.cts",
                "passWithNoTests": true,
                "coverage": true
            }
        }
    }
}
