{
    "name": "core",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "library/core/src",
    "projectType": "library",
    "tags": ["core"],
    "targets": {
        "build": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "library/core/dist",
                "main": "library/core/src/index.ts",
                "tsConfig": "library/core/tsconfig.lib.json",
                "declarationRootDir": "library/core/src",
                "format": ["esm", "cjs"],
                "external": ["@tc/*"]
            }
        }
    }
}
