{
    "name": "database",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "library/database/src",
    "projectType": "library",
    "tags": ["database", "shared"],
    "targets": {
        "build": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "library/database/dist",
                "main": "library/database/src/index.ts",
                "tsConfig": "library/database/tsconfig.lib.json",
                "declarationRootDir": "library/database/src",
                "bundle": false
            }
        },
        "migration:run": {
            "executor": "nx:run-commands",
            "dependsOn": ["database:build-migrations"],
            "options": {
                "command": "bun --env-file=.env library/database/dist/scripts/run-migrations.cjs",
                "cwd": "{workspaceRoot}"
            }
        },
        "build-migrations": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "dependsOn": ["config:build", "utils:build"],
            "options": {
                "outputPath": "library/database/dist/scripts",
                "main": "library/database/scripts/run-migrations-entry.ts",
                "tsConfig": "library/database/scripts/tsconfig.json",
                "bundle": true,
                "platform": "node",
                "format": ["cjs"],
                "outputFileName": "run-migrations.js",
                "thirdParty": true,
                "external": ["@tc/config", "@tc/utils", "typeorm", "pg", "pg-native", "reflect-metadata"]
            }
        },
        "migration:generate": {
            "executor": "nx:run-commands",
            "dependsOn": ["config:build", "utils:build"],
            "options": {
                "command": "bun ./node_modules/typeorm/cli.js migration:generate library/database/src/migrations/{args.name} --dataSource=library/database/scripts/database.datasource.ts",
                "cwd": "{workspaceRoot}"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "options": {
                "jestConfig": "library/database/jest.config.cts",
                "passWithNoTests": true
            }
        }
    }
}
