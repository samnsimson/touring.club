{
    "name": "database",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "library/database/src",
    "projectType": "library",
    "tags": ["database", "shared"],
    "targets": {
        "build": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "library/database/dist",
                "main": "library/database/src/index.ts",
                "tsConfig": "library/database/tsconfig.lib.json",
                "format": ["esm"],
                "declarationRootDir": "library/database/src"
            }
        },
        "migration:run": {
            "executor": "nx:run-commands",
            "options": {
                "command": "bunx typeorm migration:run --dataSource=library/database/src/database.datasource.ts",
                "cwd": "{workspaceRoot}"
            }
        },
        "migration:generate": {
            "executor": "nx:run-commands",
            "options": {
                "command": "bunx typeorm migration:generate library/database/src/migrations/{args.name} --dataSource=library/database/src/database.datasource.ts",
                "cwd": "{workspaceRoot}"
            }
        }
    }
}
