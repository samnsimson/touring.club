{
    "name": "config",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "library/config/src",
    "projectType": "library",
    "tags": ["config", "shared"],
    "targets": {
        "build": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "library/config/dist",
                "main": "library/config/src/index.ts",
                "tsConfig": "library/config/tsconfig.lib.json",
                "declarationRootDir": "library/config/src",
                "format": ["esm", "cjs"],
                "external": ["@tc/*"]
            }
        }
    }
}
